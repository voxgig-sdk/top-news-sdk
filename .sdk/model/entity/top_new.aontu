                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/top-news"
          parts: [
            "top-news"
          ]
          select: {
            exist: [
              "date"
              "language"
              "source_country"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
