# Entity: top_new

main: kit: entity: top_new: {

  alias: field: {}

  fields: [
    {
      name: "new"
      req: true
      type: "`$ARRAY`"
    }
  ]

  name: "top_new"
  op: {
    list: {
      name: "list"
      points: [
        {
          args: {
            query: [
              {
                kind: "query"
